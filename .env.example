# Copy this file to .env and fill in real values.

DEEPSEEK_API_KEY=

# Generate a long random value for local sessions.
FLASK_SECRET_KEY='TRTRTRTRTRT'

# Google authentication settings.
# For JWT-based login (preferred), the client obtains a Google ID token
# on the frontend and posts it to `/auth/jwt-login`. Only `GOOGLE_OAUTH_CLIENT_ID`
# is required for verifying those ID tokens.
#
# If you still want the OAuth redirect flow, set the client secret and redirect URI
# and add this authorized redirect URI in Google Cloud Console:
# http://127.0.0.1:5000/auth/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:5000/auth/google/callback

# Self-signed JWT (local auth) settings
# Local JWT auth settings. The app signs short-lived access tokens with
# JWT_SECRET_KEY and long-lived refresh tokens with REFRESH_TOKEN_SECRET.
# Refresh tokens are stored as SHA-256 hashes in AUTH_DB_PATH and rotated on use.
JWT_SECRET_KEY=
REFRESH_TOKEN_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXP_SECONDS=900
REFRESH_TOKEN_EXP_SECONDS=604800
AUTH_ALLOW_REGISTRATION=true
AUTH_COOKIE_SECURE=false
AUTH_DB_PATH=auth.db

# Optional seed user. If set, this account is created/updated at startup.
SELF_AUTH_USERNAME=
SELF_AUTH_PASSWORD=
SELF_AUTH_EMAIL=
