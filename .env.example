# Copy this file to .env and fill in real values.

DEEPSEEK_API_KEY=

# Generate a long random value for signing local JWTs.
FLASK_SECRET_KEY=

# JWT auth settings. The app signs short-lived access tokens and stores
# refresh-token hashes in AUTH_DB_PATH. Notebook notes are stored per user.
JWT_SECRET_KEY=
REFRESH_TOKEN_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXP_SECONDS=900
REFRESH_TOKEN_EXP_SECONDS=604800
AUTH_ALLOW_REGISTRATION=true
AUTH_COOKIE_SECURE=false
AUTH_DB_PATH=auth.db

# Optional seed user. If set, this account is created/updated at startup.
SELF_AUTH_USERNAME=
SELF_AUTH_PASSWORD=
SELF_AUTH_EMAIL=
