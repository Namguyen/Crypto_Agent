# Copy this file to .env and fill in real values.

DEEPSEEK_API_KEY=

# Chat mode settings. Instant is the low-cost default. Reasoning can use the
# same model with deeper prompting, or a stronger model if your provider supports it.
INSTANT_MODEL=deepseek-v4-flash
REASONING_MODEL=deepseek-v4-pro
INSTANT_MAX_TOKENS=700
REASONING_MAX_TOKENS=1600
INSTANT_MAX_TOOL_ROUNDS=2
REASONING_MAX_TOOL_ROUNDS=4

# Generate a long random value for signing local JWTs.
FLASK_SECRET_KEY=

# JWT auth settings. The app signs short-lived access tokens and stores
# refresh-token hashes in AUTH_DB_PATH. Notebook notes are stored per user.
JWT_SECRET_KEY=
REFRESH_TOKEN_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXP_SECONDS=900
REFRESH_TOKEN_EXP_SECONDS=604800
AUTH_ALLOW_REGISTRATION=true
AUTH_COOKIE_SECURE=false
AUTH_DB_PATH=auth.db

# Optional seed user. If set, this account is created/updated at startup.
SELF_AUTH_USERNAME=
SELF_AUTH_PASSWORD=
SELF_AUTH_EMAIL=
